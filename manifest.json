{
  "manifest_version": 3,
  "name": "Yandex Music Track Collector",
  "version": "1.3",
  "description": "Собирает треки из плейлистов Яндекс.Музыки при прокрутке",
  "permissions": ["storage", "downloads", "tabs"],
  "host_permissions": [
    "*://music.yandex.ru/*",
    "*://music.yandex.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://music.yandex.ru/*",
        "*://music.yandex.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YM Track Collector"
  }
}
